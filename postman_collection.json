							"});",
							"",
							"pm.test('Response contains stock info', function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('article_id');",
							"    pm.expect(jsonData).to.have.property('current_stock');",
							"    pm.expect(jsonData).to.have.property('available_stock');",
							"    pm.expect(jsonData).to.have.property('reserved_stock');",
