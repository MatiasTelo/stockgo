		{
			"name": "1. Add Article",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 201', function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test('Response contains success message', function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('message');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"article_id\": \"{{article_id}}\",\n    \"name\": \"Producto de Prueba\",\n    \"description\": \"Descripción del producto de prueba\",\n    \"initial_stock\": 100,\n    \"min_stock\": 10,\n    \"max_stock\": 500,\n    \"unit_price\": 25.50,\n    \"location\": \"A1-B2-C3\",\n    \"metadata\": {\n        \"category\": \"electronics\",\n        \"supplier\": \"Supplier ABC\",\n        \"weight\": \"0.5kg\"\n    }\n}"
				},
